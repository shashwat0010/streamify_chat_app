# ==========================================
# Streamify Frontend Environment Variables Example
# ==========================================

# Production Gateway URL (Behind Nginx, routes through /api)
VITE_BACKEND_URL=https://streamify.yourdomain.com/api

# Clerk Authentication Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# GetStream Video calling API Publishable Key
VITE_STREAM_API_KEY=your_getstream_api_key
