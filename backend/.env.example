# ==========================================
# Streamify Backend Environment Variables Example
# ==========================================

PORT=5001
NODE_ENV=production

# MongoDB Production Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/streamify?retryWrites=true&w=majority

# Redis Cache Service Connection URL (set to "redis://redis:6379" for Docker Compose)
REDIS_URL=redis://redis:6379

# Client Address (Your production frontend URL)
CLIENT_URL=https://streamify.yourdomain.com

# Clerk Authentication Keys (Get from Dashboard)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# GetStream Video calling API Keys (Get from Dashboard)
STREAM_API_KEY=your_getstream_api_key
STREAM_API_SECRET=your_getstream_api_secret

# JWT Key (For secondary internal token verification if needed)
JWT_SECRET_KEY=your_fallback_jwt_secret_key_random_string

# AWS S3 Cloud Object Storage Configuration (For file & image uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA... # IAM user with PutObject permission on the bucket
AWS_SECRET_ACCESS_KEY=your_aws_s3_secret_access_key
AWS_S3_BUCKET_NAME=streamify-production-uploads
